#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

set -e

echo "🚀 Pre-push validations..."

echo "📘 Type checking..."
npm run type-check

echo "🔍 ESLint..."
npm run lint

echo "🧪 Tests..."
npm test

echo "🔒 Security check..."
node scripts/security-check.cjs --quick

echo "📦 Build validation..."
node scripts/build-validations.cjs

echo "✅ Pre-push validations passed."
