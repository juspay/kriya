#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

set -e

# 1) Commitlint (conventional-commits rules)
npx --no -- commitlint --edit "$1"

# 2) Custom semantic validator (anti-patterns, typos, quality heuristics)
if [ -f "scripts/commit-validation.cjs" ]; then
  node scripts/commit-validation.cjs "$1"
fi
